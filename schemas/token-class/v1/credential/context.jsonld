{
    "@context": {
        "@import": "https://finternet-io.github.io/specs/schemas/token-class/v1/base/context.jsonld",
        "vc": "https://www.w3.org/2018/credentials#",
        "sec": "https://w3id.org/security#",
        "finternet": "https://finternet-io.github.io/specs/schemas/token-class/v1#",

        "CredentialTokenClass": "finternet:CredentialTokenClass",
        "VerifiableCredential": "vc:VerifiableCredential",

        "credentialType": { "@id": "finternet:credentialType", "@type": "@vocab" },
        "verificationLevel": { "@id": "finternet:verificationLevel", "@type": "@vocab" },

        "claims": { "@id": "finternet:claims", "@container": "@set" },
        "issuer": { "@id": "vc:issuer", "@type": "@id" },
        "issuanceDate": { "@id": "vc:issuanceDate", "@type": "xsd:dateTime" },
        "expirationDate": { "@id": "vc:expirationDate", "@type": "xsd:dateTime" },
        "validFrom": { "@id": "vc:validFrom", "@type": "xsd:dateTime" },
        "validUntil": { "@id": "vc:validUntil", "@type": "xsd:dateTime" },
        "credentialSubject": "vc:credentialSubject",
        "credentialStatus": "vc:credentialStatus",
        "credentialSchema": "vc:credentialSchema",
        "evidence": { "@id": "vc:evidence", "@container": "@set" },
        "proof": "sec:proof",

        "DocumentVerification": "finternet:DocumentVerification",
        "BiometricVerification": "finternet:BiometricVerification",
        "IdentityEvidence": "finternet:IdentityEvidence",

        "documentType": { "@id": "finternet:documentType", "@type": "@vocab" },
        "documentCountry": "finternet:documentCountry",
        "documentValid": { "@id": "finternet:documentValid", "@type": "xsd:boolean" },
        "livenessVerified": { "@id": "finternet:livenessVerified", "@type": "xsd:boolean" },
        "livenessScore": { "@id": "finternet:livenessScore", "@type": "xsd:decimal" },
        "faceMatchVerified": { "@id": "finternet:faceMatchVerified", "@type": "xsd:boolean" },
        "faceMatchScore": { "@id": "finternet:faceMatchScore", "@type": "xsd:decimal" }
    }
}
