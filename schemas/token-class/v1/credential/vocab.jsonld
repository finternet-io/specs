{
    "@context": {
        "rdf": "http://www.w3.org/1999/02/22-rdf-syntax-ns#",
        "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
        "owl": "http://www.w3.org/2002/07/owl#",
        "xsd": "http://www.w3.org/2001/XMLSchema#",
        "vc": "https://www.w3.org/2018/credentials#",
        "finternet": "https://finternet-io.github.io/specs/schemas/token-class/v1#"
    },
    "@graph": [
        {
            "@id": "finternet:CredentialTokenClass",
            "@type": "rdfs:Class",
            "rdfs:subClassOf": { "@id": "finternet:NonFungibleTokenClass" },
            "rdfs:label": "CredentialTokenClass",
            "rdfs:comment": "Token class for soulbound credential tokens. Non-transferable, W3C VC compliant."
        },
        {
            "@id": "finternet:credentialType",
            "@type": "rdf:Property",
            "rdfs:label": "credentialType",
            "rdfs:comment": "Type of credential verification (identity, document, biometric, KYC).",
            "rdfs:domain": { "@id": "finternet:CredentialTokenClass" },
            "rdfs:range": { "@id": "finternet:CredentialTypeEnum" }
        },
        {
            "@id": "finternet:CredentialTypeEnum",
            "@type": "rdfs:Class",
            "owl:oneOf": {
                "@list": [
                    { "@id": "finternet:identityVerification" },
                    { "@id": "finternet:documentVerification" },
                    { "@id": "finternet:biometricVerification" },
                    { "@id": "finternet:kycVerification" },
                    { "@id": "finternet:addressVerification" },
                    { "@id": "finternet:ageVerification" }
                ]
            }
        },
        {
            "@id": "finternet:verificationLevel",
            "@type": "rdf:Property",
            "rdfs:label": "verificationLevel",
            "rdfs:comment": "Level of assurance for the verification (aligned with eIDAS).",
            "rdfs:domain": { "@id": "finternet:CredentialTokenClass" },
            "rdfs:range": { "@id": "finternet:VerificationLevelEnum" }
        },
        {
            "@id": "finternet:VerificationLevelEnum",
            "@type": "rdfs:Class",
            "owl:oneOf": {
                "@list": [
                    { "@id": "finternet:basic" },
                    { "@id": "finternet:standard" },
                    { "@id": "finternet:enhanced" },
                    { "@id": "finternet:premium" }
                ]
            }
        },
        {
            "@id": "finternet:claims",
            "@type": "rdf:Property",
            "rdfs:label": "claims",
            "rdfs:comment": "Array of W3C Verifiable Credentials attached to this token class.",
            "rdfs:domain": { "@id": "finternet:CredentialTokenClass" },
            "rdfs:range": { "@id": "vc:VerifiableCredential" }
        },
        {
            "@id": "finternet:DocumentVerification",
            "@type": "rdfs:Class",
            "rdfs:label": "DocumentVerification",
            "rdfs:comment": "Document verification evidence."
        },
        {
            "@id": "finternet:BiometricVerification",
            "@type": "rdfs:Class",
            "rdfs:label": "BiometricVerification",
            "rdfs:comment": "Biometric verification evidence (liveness, face match)."
        },
        {
            "@id": "finternet:IdentityEvidence",
            "@type": "rdfs:Class",
            "rdfs:subClassOf": { "@id": "vc:Evidence" },
            "rdfs:label": "IdentityEvidence",
            "rdfs:comment": "W3C VC Evidence extension for identity verification."
        },
        {
            "@id": "finternet:DocumentTypeEnum",
            "@type": "rdfs:Class",
            "owl:oneOf": {
                "@list": [
                    { "@id": "finternet:passport" },
                    { "@id": "finternet:nationalId" },
                    { "@id": "finternet:driversLicense" },
                    { "@id": "finternet:pan" },
                    { "@id": "finternet:aadhaar" },
                    { "@id": "finternet:voterId" }
                ]
            }
        }
    ]
}
