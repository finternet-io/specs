{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://finternet-io.github.io/specs/schemas/credential/v1/credential.schema.json",
  "title": "Credential Token Schema",
  "description": "JSON Schema for validating Finternet Credential Tokens with W3C VC compliance",
  "type": "object",
  "required": ["@context", "@type", "id", "metadata", "claims", "identities", "state"],
  "properties": {
    "@context": {
      "description": "JSON-LD context",
      "oneOf": [
        { "type": "string", "format": "uri" },
        {
          "type": "array",
          "items": {
            "oneOf": [
              { "type": "string", "format": "uri" },
              { "type": "object" }
            ]
          }
        }
      ]
    },
    "@type": {
      "description": "Token type",
      "const": "CredentialToken"
    },
    "id": {
      "type": "string",
      "format": "uri",
      "description": "Unique token identifier"
    },
    "metadata": {
      "$ref": "#/$defs/CredentialMetadata"
    },
    "data": {
      "type": "object",
      "description": "Additional credential-specific data",
      "additionalProperties": true
    },
    "claims": {
      "type": "array",
      "description": "Verifiable Credentials",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/VerifiableCredential"
      }
    },
    "identities": {
      "type": "array",
      "description": "Identity relationships",
      "items": {
        "$ref": "#/$defs/CredentialIdentity"
      }
    },
    "state": {
      "$ref": "#/$defs/CredentialState"
    }
  },
  "$defs": {
    "CredentialMetadata": {
      "type": "object",
      "description": "Credentials are always Non-Fungible Tokens (NFT) - unique and non-transferable",
      "required": ["tokenStandard", "name", "credentialType", "verificationLevel"],
      "properties": {
        "tokenStandard": {
          "type": "array",
          "description": "Token standards. First = primary, must include soulbound standard.",
          "items": { "type": "string" },
          "minItems": 1,
          "examples": [
            ["UNITS-SBT"],
            ["UNITS-SBT", "W3C-VC-2.0"],
            ["UNITS-SBT", "W3C-VC-2.0", "ERC-6239"]
          ]
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "symbol": {
          "type": "string",
          "maxLength": 20
        },
        "fungibility": {
          "const": "nonFungible",
          "description": "Credentials are always non-fungible - each is unique to its subject"
        },
        "decimals": {
          "const": 0,
          "description": "Credentials have no decimal places (NFT characteristic)"
        },
        "credentialType": {
          "$ref": "#/$defs/CredentialType"
        },
        "verificationLevel": {
          "$ref": "#/$defs/VerificationLevel"
        },
        "provider": {
          "$ref": "#/$defs/VerificationProvider"
        },
        "consentGiven": {
          "type": "boolean"
        },
        "consentTimestamp": {
          "type": "string",
          "format": "date-time"
        },
        "version": {
          "type": "string",
          "default": "1.0.0"
        },
        "status": {
          "type": "string",
          "enum": ["active", "inactive", "deprecated"]
        },
        "flags": {
          "type": "object",
          "description": "Behavioral flags for credential tokens (soulbound NFTs)",
          "properties": {
            "transactable": { "type": "boolean", "default": true },
            "transferable": {
              "const": false,
              "description": "Credentials are soulbound and cannot be transferred"
            },
            "divisible": {
              "const": false,
              "description": "Credentials are non-divisible (NFT characteristic)"
            },
            "locked": { "type": "boolean", "default": false },
            "revocable": { "type": "boolean", "default": true },
            "burnable": {
              "const": false,
              "description": "Credentials cannot be burned by the holder"
            }
          }
        },
        "description": {
          "type": "string"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "CredentialType": {
      "type": "string",
      "enum": [
        "identityVerification",
        "documentVerification",
        "biometricVerification",
        "kycVerification",
        "addressVerification",
        "ageVerification"
      ]
    },
    "VerificationLevel": {
      "type": "string",
      "enum": ["basic", "standard", "enhanced", "premium"]
    },
    "VerificationProvider": {
      "type": "object",
      "required": ["providerName", "providerId"],
      "properties": {
        "providerName": {
          "type": "string",
          "description": "Human-readable provider name"
        },
        "providerId": {
          "type": "string",
          "description": "Unique provider identifier"
        },
        "providerType": {
          "type": "string",
          "enum": ["kycProvider", "documentProvider", "biometricProvider"]
        },
        "journeyId": {
          "type": "string",
          "description": "Provider session/journey ID"
        },
        "flowId": {
          "type": "string",
          "format": "uuid",
          "description": "Provider workflow ID"
        },
        "flowVersion": {
          "type": "integer",
          "minimum": 1
        },
        "rawResponseRef": {
          "type": "string",
          "format": "uri",
          "description": "Reference to encrypted raw response"
        },
        "rawResponseHash": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$",
          "description": "SHA-256 hash of raw response"
        },
        "encryptionKeyRef": {
          "type": "string",
          "format": "uri",
          "description": "Reference to encryption key"
        }
      }
    },
    "VerifiableCredential": {
      "type": "object",
      "description": "W3C Verifiable Credential",
      "required": ["@context", "type", "issuer", "issuanceDate", "credentialSubject"],
      "properties": {
        "id": {
          "type": "string",
          "format": "uri"
        },
        "@context": {
          "oneOf": [
            { "type": "string" },
            {
              "type": "array",
              "items": {
                "oneOf": [
                  { "type": "string" },
                  { "type": "object" }
                ]
              },
              "contains": {
                "const": "https://www.w3.org/2018/credentials/v1"
              }
            }
          ]
        },
        "type": {
          "oneOf": [
            { "type": "string" },
            {
              "type": "array",
              "items": { "type": "string" },
              "contains": { "const": "VerifiableCredential" }
            }
          ]
        },
        "issuer": {
          "oneOf": [
            { "type": "string", "format": "uri" },
            {
              "type": "object",
              "required": ["id"],
              "properties": {
                "id": { "type": "string", "format": "uri" },
                "name": { "type": "string" }
              }
            }
          ]
        },
        "issuanceDate": {
          "type": "string",
          "format": "date-time"
        },
        "validFrom": {
          "type": "string",
          "format": "date-time"
        },
        "expirationDate": {
          "type": "string",
          "format": "date-time"
        },
        "validUntil": {
          "type": "string",
          "format": "date-time"
        },
        "credentialSubject": {
          "$ref": "#/$defs/CredentialSubject"
        },
        "credentialStatus": {
          "$ref": "#/$defs/CredentialStatus"
        },
        "credentialSchema": {
          "$ref": "#/$defs/CredentialSchema"
        },
        "evidence": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/Evidence"
          }
        },
        "termsOfUse": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/TermsOfUse"
          }
        },
        "proof": {
          "oneOf": [
            { "$ref": "#/$defs/Proof" },
            {
              "type": "array",
              "items": { "$ref": "#/$defs/Proof" }
            }
          ]
        }
      }
    },
    "CredentialSubject": {
      "type": "object",
      "required": ["id"],
      "properties": {
        "id": {
          "type": "string",
          "format": "uri"
        },
        "fullName": { "type": "string" },
        "givenName": { "type": "string" },
        "familyName": { "type": "string" },
        "dateOfBirth": { "type": "string", "format": "date" },
        "gender": { "type": "string" },
        "nationality": { "type": "string" },
        "address": { "$ref": "#/$defs/PostalAddress" }
      },
      "additionalProperties": true
    },
    "PostalAddress": {
      "type": "object",
      "properties": {
        "streetAddress": { "type": "string" },
        "addressLocality": { "type": "string" },
        "addressRegion": { "type": "string" },
        "postalCode": { "type": "string" },
        "addressCountry": { "type": "string", "pattern": "^[A-Z]{2}$" }
      }
    },
    "CredentialStatus": {
      "type": "object",
      "required": ["id", "type"],
      "properties": {
        "id": { "type": "string", "format": "uri" },
        "type": {
          "type": "string",
          "enum": ["StatusList2021Entry", "RevocationList2020Status", "BitstringStatusListEntry"]
        },
        "statusPurpose": {
          "type": "string",
          "enum": ["revocation", "suspension"]
        },
        "statusListIndex": { "type": "string" },
        "statusListCredential": { "type": "string", "format": "uri" }
      }
    },
    "CredentialSchema": {
      "type": "object",
      "required": ["id", "type"],
      "properties": {
        "id": { "type": "string", "format": "uri" },
        "type": {
          "type": "string",
          "enum": ["JsonSchema", "JsonSchemaCredential"]
        }
      }
    },
    "Evidence": {
      "type": "object",
      "properties": {
        "id": { "type": "string", "format": "uri" },
        "type": {
          "oneOf": [
            { "type": "string" },
            { "type": "array", "items": { "type": "string" } }
          ]
        },
        "documentVerification": { "$ref": "#/$defs/DocumentVerification" },
        "biometricVerification": { "$ref": "#/$defs/BiometricVerification" },
        "verificationTimestamp": { "type": "string", "format": "date-time" }
      },
      "additionalProperties": true
    },
    "DocumentVerification": {
      "type": "object",
      "required": ["documentType", "documentCountry", "documentValid"],
      "properties": {
        "documentType": {
          "type": "string",
          "enum": ["passport", "nationalId", "driversLicense", "pan", "aadhaar", "voterId"]
        },
        "documentCountry": {
          "type": "string",
          "pattern": "^[A-Z]{2}$"
        },
        "documentNumber": {
          "type": "string",
          "description": "Masked document number"
        },
        "documentExpiry": {
          "type": "string",
          "format": "date"
        },
        "documentValid": {
          "type": "boolean"
        },
        "verificationMethod": {
          "type": "string",
          "enum": ["optical", "ocr", "nfc", "api", "manual"]
        },
        "verificationAttempts": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "BiometricVerification": {
      "type": "object",
      "properties": {
        "livenessScore": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0
        },
        "livenessVerified": {
          "type": "boolean"
        },
        "faceMatchScore": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0
        },
        "faceMatchVerified": {
          "type": "boolean"
        },
        "verificationAttempts": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "TermsOfUse": {
      "type": "object",
      "properties": {
        "id": { "type": "string", "format": "uri" },
        "type": { "type": "string" },
        "profile": { "type": "string", "format": "uri" }
      }
    },
    "Proof": {
      "type": "object",
      "required": ["type", "created", "verificationMethod", "proofPurpose"],
      "properties": {
        "type": { "type": "string" },
        "created": { "type": "string", "format": "date-time" },
        "verificationMethod": { "type": "string", "format": "uri" },
        "proofPurpose": {
          "type": "string",
          "enum": ["assertionMethod", "authentication", "keyAgreement", "capabilityInvocation", "capabilityDelegation"]
        },
        "proofValue": { "type": "string" },
        "jws": { "type": "string" },
        "challenge": { "type": "string" },
        "domain": { "type": "string" },
        "cryptosuite": { "type": "string" }
      }
    },
    "CredentialIdentity": {
      "type": "object",
      "required": ["id", "type"],
      "properties": {
        "id": {
          "type": "string",
          "format": "uri"
        },
        "type": {
          "type": "string",
          "enum": ["issuer", "subject", "holder", "verifier"]
        }
      }
    },
    "CredentialState": {
      "type": "object",
      "required": ["status", "balance"],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["active", "suspended", "revoked", "expired"]
        },
        "balance": {
          "const": "1",
          "description": "Credentials always have a balance of 1 (NFT characteristic)"
        },
        "effectiveFrom": {
          "type": "string",
          "format": "date-time"
        },
        "effectiveUntil": {
          "type": "string",
          "format": "date-time"
        },
        "verificationAttempts": {
          "type": "integer",
          "minimum": 0
        },
        "customState": {
          "type": "object",
          "additionalProperties": true
        },
        "stateCommitment": {
          "type": "string"
        }
      }
    }
  }
}
