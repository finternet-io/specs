{
    "@context": {
        "finternet": "https://finternet-io.github.io/specs/schemas/credential/v1#",
        "schema": "https://schema.org/",
        "rdf": "http://www.w3.org/1999/02/22-rdf-syntax-ns#",
        "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
        "xsd": "http://www.w3.org/2001/XMLSchema#",
        "sec": "https://w3id.org/security#",
        "vc": "https://www.w3.org/2018/credentials#"
    },
    "@graph": [
        {
            "@id": "finternet:CredentialToken",
            "@type": "rdfs:Class",
            "rdfs:subClassOf": "https://finternet-io.github.io/specs/schemas/token/v1#NonFungibleToken",
            "rdfs:label": "CredentialToken",
            "rdfs:comment": "A token representing a verifiable credential, extending NonFungibleToken with W3C VC compliance. Credentials are soulbound NFTs (transferable=false) used to tokenize identity verification results, KYC attestations, and other verifiable claims."
        },
        {
            "@id": "finternet:CredentialMetadata",
            "@type": "rdfs:Class",
            "rdfs:subClassOf": "https://finternet-io.github.io/specs/schemas/token/v1#TokenMetadata",
            "rdfs:label": "CredentialMetadata",
            "rdfs:comment": "Extended metadata for credential tokens, including credential type, verification level, and provider information."
        },
        {
            "@id": "finternet:CredentialState",
            "@type": "rdfs:Class",
            "rdfs:subClassOf": "https://finternet-io.github.io/specs/schemas/token/v1#TokenState",
            "rdfs:label": "CredentialState",
            "rdfs:comment": "Runtime state for credential tokens, including verification status and validity period."
        },

        {
            "@id": "finternet:credentialType",
            "@type": "rdf:Property",
            "rdfs:label": "credentialType",
            "rdfs:comment": "The type of credential (identity, document, biometric, KYC, etc.).",
            "rdfs:domain": "finternet:CredentialMetadata",
            "rdfs:range": "finternet:CredentialType"
        },
        {
            "@id": "finternet:CredentialType",
            "@type": "schema:Enumeration",
            "schema:name": "CredentialType",
            "rdfs:comment": "Enumeration of credential types supported by the system.",
            "schema:hasEnumerationMember": [
                { "@id": "finternet:identityVerification" },
                { "@id": "finternet:documentVerification" },
                { "@id": "finternet:biometricVerification" },
                { "@id": "finternet:kycVerification" },
                { "@id": "finternet:addressVerification" },
                { "@id": "finternet:ageVerification" }
            ]
        },
        {
            "@id": "finternet:identityVerification",
            "@type": ["finternet:CredentialType", "schema:Enumeration"],
            "schema:name": "Identity Verification",
            "schema:identifier": "identityVerification",
            "rdfs:comment": "Full identity verification combining document and biometric checks."
        },
        {
            "@id": "finternet:documentVerification",
            "@type": ["finternet:CredentialType", "schema:Enumeration"],
            "schema:name": "Document Verification",
            "schema:identifier": "documentVerification",
            "rdfs:comment": "Verification of identity documents (passport, ID card, etc.)."
        },
        {
            "@id": "finternet:biometricVerification",
            "@type": ["finternet:CredentialType", "schema:Enumeration"],
            "schema:name": "Biometric Verification",
            "schema:identifier": "biometricVerification",
            "rdfs:comment": "Biometric verification (face match, liveness, fingerprint)."
        },
        {
            "@id": "finternet:kycVerification",
            "@type": ["finternet:CredentialType", "schema:Enumeration"],
            "schema:name": "KYC Verification",
            "schema:identifier": "kycVerification",
            "rdfs:comment": "Comprehensive Know Your Customer verification."
        },
        {
            "@id": "finternet:addressVerification",
            "@type": ["finternet:CredentialType", "schema:Enumeration"],
            "schema:name": "Address Verification",
            "schema:identifier": "addressVerification",
            "rdfs:comment": "Verification of residential or business address."
        },
        {
            "@id": "finternet:ageVerification",
            "@type": ["finternet:CredentialType", "schema:Enumeration"],
            "schema:name": "Age Verification",
            "schema:identifier": "ageVerification",
            "rdfs:comment": "Verification of age/date of birth without full identity disclosure."
        },

        {
            "@id": "finternet:verificationLevel",
            "@type": "rdf:Property",
            "rdfs:label": "verificationLevel",
            "rdfs:comment": "Level of assurance for the verification (basic, standard, enhanced, premium).",
            "rdfs:domain": "finternet:CredentialMetadata",
            "rdfs:range": "finternet:VerificationLevel"
        },
        {
            "@id": "finternet:VerificationLevel",
            "@type": "schema:Enumeration",
            "schema:name": "VerificationLevel",
            "rdfs:comment": "Level of assurance for identity verification, based on eIDAS and similar frameworks.",
            "schema:hasEnumerationMember": [
                { "@id": "finternet:basic" },
                { "@id": "finternet:standard" },
                { "@id": "finternet:enhanced" },
                { "@id": "finternet:premium" }
            ]
        },
        {
            "@id": "finternet:basic",
            "@type": ["finternet:VerificationLevel", "schema:Enumeration"],
            "schema:name": "Basic",
            "schema:identifier": "basic",
            "rdfs:comment": "Basic verification with minimal checks (self-attestation or simple document upload)."
        },
        {
            "@id": "finternet:standard",
            "@type": ["finternet:VerificationLevel", "schema:Enumeration"],
            "schema:name": "Standard",
            "schema:identifier": "standard",
            "rdfs:comment": "Standard verification with document OCR and basic validation."
        },
        {
            "@id": "finternet:enhanced",
            "@type": ["finternet:VerificationLevel", "schema:Enumeration"],
            "schema:name": "Enhanced",
            "schema:identifier": "enhanced",
            "rdfs:comment": "Enhanced verification with liveness detection and face matching."
        },
        {
            "@id": "finternet:premium",
            "@type": ["finternet:VerificationLevel", "schema:Enumeration"],
            "schema:name": "Premium",
            "schema:identifier": "premium",
            "rdfs:comment": "Premium verification with government database checks and manual review."
        },

        {
            "@id": "finternet:VerificationProvider",
            "@type": "rdfs:Class",
            "rdfs:label": "VerificationProvider",
            "rdfs:comment": "Information about the third-party provider that performed the verification."
        },
        {
            "@id": "finternet:provider",
            "@type": "rdf:Property",
            "rdfs:label": "provider",
            "rdfs:comment": "The verification provider that issued this credential.",
            "rdfs:domain": "finternet:CredentialMetadata",
            "rdfs:range": "finternet:VerificationProvider"
        },
        {
            "@id": "finternet:providerName",
            "@type": "rdf:Property",
            "rdfs:label": "providerName",
            "rdfs:comment": "Human-readable name of the verification provider.",
            "rdfs:domain": "finternet:VerificationProvider",
            "rdfs:range": "xsd:string"
        },
        {
            "@id": "finternet:providerId",
            "@type": "rdf:Property",
            "rdfs:label": "providerId",
            "rdfs:comment": "Unique identifier for the verification provider.",
            "rdfs:domain": "finternet:VerificationProvider",
            "rdfs:range": "xsd:string"
        },
        {
            "@id": "finternet:providerType",
            "@type": "rdf:Property",
            "rdfs:label": "providerType",
            "rdfs:comment": "Type of verification provider.",
            "rdfs:domain": "finternet:VerificationProvider",
            "rdfs:range": "finternet:ProviderType"
        },
        {
            "@id": "finternet:ProviderType",
            "@type": "schema:Enumeration",
            "schema:name": "ProviderType",
            "rdfs:comment": "Types of verification providers.",
            "schema:hasEnumerationMember": [
                { "@id": "finternet:kycProvider" },
                { "@id": "finternet:documentProvider" },
                { "@id": "finternet:biometricProvider" }
            ]
        },

        {
            "@id": "finternet:journeyId",
            "@type": "rdf:Property",
            "rdfs:label": "journeyId",
            "rdfs:comment": "Provider-specific journey/session identifier for the verification process.",
            "rdfs:domain": "finternet:VerificationProvider",
            "rdfs:range": "xsd:string"
        },
        {
            "@id": "finternet:flowId",
            "@type": "rdf:Property",
            "rdfs:label": "flowId",
            "rdfs:comment": "Provider-specific flow/workflow identifier.",
            "rdfs:domain": "finternet:VerificationProvider",
            "rdfs:range": "xsd:string"
        },
        {
            "@id": "finternet:flowVersion",
            "@type": "rdf:Property",
            "rdfs:label": "flowVersion",
            "rdfs:comment": "Version of the verification flow used.",
            "rdfs:domain": "finternet:VerificationProvider",
            "rdfs:range": "xsd:integer"
        },

        {
            "@id": "finternet:DocumentVerification",
            "@type": "rdfs:Class",
            "rdfs:label": "DocumentVerification",
            "rdfs:comment": "Results of document verification including document type, validity, and extracted data."
        },
        {
            "@id": "finternet:documentType",
            "@type": "rdf:Property",
            "rdfs:label": "documentType",
            "rdfs:comment": "Type of identity document verified.",
            "rdfs:domain": "finternet:DocumentVerification",
            "rdfs:range": "finternet:DocumentType"
        },
        {
            "@id": "finternet:DocumentType",
            "@type": "schema:Enumeration",
            "schema:name": "DocumentType",
            "rdfs:comment": "Types of identity documents supported for verification.",
            "schema:hasEnumerationMember": [
                { "@id": "finternet:passport" },
                { "@id": "finternet:nationalId" },
                { "@id": "finternet:driversLicense" },
                { "@id": "finternet:pan" },
                { "@id": "finternet:aadhaar" },
                { "@id": "finternet:voterId" }
            ]
        },
        {
            "@id": "finternet:passport",
            "@type": ["finternet:DocumentType", "schema:Enumeration"],
            "schema:name": "Passport",
            "schema:identifier": "passport"
        },
        {
            "@id": "finternet:nationalId",
            "@type": ["finternet:DocumentType", "schema:Enumeration"],
            "schema:name": "National ID",
            "schema:identifier": "nationalId"
        },
        {
            "@id": "finternet:driversLicense",
            "@type": ["finternet:DocumentType", "schema:Enumeration"],
            "schema:name": "Driver's License",
            "schema:identifier": "driversLicense"
        },
        {
            "@id": "finternet:pan",
            "@type": ["finternet:DocumentType", "schema:Enumeration"],
            "schema:name": "PAN Card",
            "schema:identifier": "pan",
            "rdfs:comment": "Permanent Account Number card issued by India Income Tax Department."
        },
        {
            "@id": "finternet:aadhaar",
            "@type": ["finternet:DocumentType", "schema:Enumeration"],
            "schema:name": "Aadhaar",
            "schema:identifier": "aadhaar",
            "rdfs:comment": "Unique Identification Authority of India (UIDAI) Aadhaar card."
        },
        {
            "@id": "finternet:voterId",
            "@type": ["finternet:DocumentType", "schema:Enumeration"],
            "schema:name": "Voter ID",
            "schema:identifier": "voterId"
        },

        {
            "@id": "finternet:verificationMethod",
            "@type": "rdf:Property",
            "rdfs:label": "verificationMethod",
            "rdfs:comment": "Method used to verify the document.",
            "rdfs:domain": "finternet:DocumentVerification",
            "rdfs:range": "finternet:VerificationMethod"
        },
        {
            "@id": "finternet:VerificationMethod",
            "@type": "schema:Enumeration",
            "schema:name": "VerificationMethod",
            "rdfs:comment": "Methods used for document verification.",
            "schema:hasEnumerationMember": [
                { "@id": "finternet:optical" },
                { "@id": "finternet:ocr" },
                { "@id": "finternet:nfc" },
                { "@id": "finternet:api" },
                { "@id": "finternet:manual" }
            ]
        },
        {
            "@id": "finternet:optical",
            "@type": ["finternet:VerificationMethod", "schema:Enumeration"],
            "schema:name": "Optical",
            "schema:identifier": "optical",
            "rdfs:comment": "Optical verification using camera capture and image analysis."
        },
        {
            "@id": "finternet:ocr",
            "@type": ["finternet:VerificationMethod", "schema:Enumeration"],
            "schema:name": "OCR",
            "schema:identifier": "ocr",
            "rdfs:comment": "Optical Character Recognition to extract text from documents."
        },
        {
            "@id": "finternet:nfc",
            "@type": ["finternet:VerificationMethod", "schema:Enumeration"],
            "schema:name": "NFC",
            "schema:identifier": "nfc",
            "rdfs:comment": "Near Field Communication chip reading."
        },
        {
            "@id": "finternet:api",
            "@type": ["finternet:VerificationMethod", "schema:Enumeration"],
            "schema:name": "API",
            "schema:identifier": "api",
            "rdfs:comment": "Verification via government or issuer API."
        },
        {
            "@id": "finternet:manual",
            "@type": ["finternet:VerificationMethod", "schema:Enumeration"],
            "schema:name": "Manual",
            "schema:identifier": "manual",
            "rdfs:comment": "Manual verification by a human reviewer."
        },

        {
            "@id": "finternet:documentCountry",
            "@type": "rdf:Property",
            "rdfs:label": "documentCountry",
            "rdfs:comment": "ISO 3166-1 alpha-2 country code of the document issuing country.",
            "rdfs:domain": "finternet:DocumentVerification",
            "rdfs:range": "xsd:string"
        },
        {
            "@id": "finternet:documentValid",
            "@type": "rdf:Property",
            "rdfs:label": "documentValid",
            "rdfs:comment": "Whether the document passed all verification checks.",
            "rdfs:domain": "finternet:DocumentVerification",
            "rdfs:range": "xsd:boolean"
        },

        {
            "@id": "finternet:BiometricVerification",
            "@type": "rdfs:Class",
            "rdfs:label": "BiometricVerification",
            "rdfs:comment": "Results of biometric verification including liveness and face matching."
        },
        {
            "@id": "finternet:livenessScore",
            "@type": "rdf:Property",
            "rdfs:label": "livenessScore",
            "rdfs:comment": "Confidence score for liveness detection (0.0 to 1.0).",
            "rdfs:domain": "finternet:BiometricVerification",
            "rdfs:range": "xsd:decimal"
        },
        {
            "@id": "finternet:livenessVerified",
            "@type": "rdf:Property",
            "rdfs:label": "livenessVerified",
            "rdfs:comment": "Whether liveness check passed.",
            "rdfs:domain": "finternet:BiometricVerification",
            "rdfs:range": "xsd:boolean"
        },
        {
            "@id": "finternet:faceMatchScore",
            "@type": "rdf:Property",
            "rdfs:label": "faceMatchScore",
            "rdfs:comment": "Confidence score for face matching against document photo (0.0 to 1.0).",
            "rdfs:domain": "finternet:BiometricVerification",
            "rdfs:range": "xsd:decimal"
        },
        {
            "@id": "finternet:faceMatchVerified",
            "@type": "rdf:Property",
            "rdfs:label": "faceMatchVerified",
            "rdfs:comment": "Whether face match check passed.",
            "rdfs:domain": "finternet:BiometricVerification",
            "rdfs:range": "xsd:boolean"
        },

        {
            "@id": "finternet:IdentityEvidence",
            "@type": "rdfs:Class",
            "rdfs:subClassOf": "vc:Evidence",
            "rdfs:label": "IdentityEvidence",
            "rdfs:comment": "W3C VC Evidence extension for identity verification, containing document and biometric verification results."
        },

        {
            "@id": "finternet:rawResponseRef",
            "@type": "rdf:Property",
            "rdfs:label": "rawResponseRef",
            "rdfs:comment": "Reference to the encrypted raw response from the verification provider, stored externally.",
            "rdfs:domain": "finternet:VerificationProvider",
            "rdfs:range": "xsd:anyURI"
        },
        {
            "@id": "finternet:rawResponseHash",
            "@type": "rdf:Property",
            "rdfs:label": "rawResponseHash",
            "rdfs:comment": "SHA-256 hash of the raw response for integrity verification.",
            "rdfs:domain": "finternet:VerificationProvider",
            "rdfs:range": "xsd:string"
        },
        {
            "@id": "finternet:encryptionKeyRef",
            "@type": "rdf:Property",
            "rdfs:label": "encryptionKeyRef",
            "rdfs:comment": "Reference to the encryption key used to encrypt the raw response.",
            "rdfs:domain": "finternet:VerificationProvider",
            "rdfs:range": "xsd:anyURI"
        },

        {
            "@id": "finternet:consentGiven",
            "@type": "rdf:Property",
            "rdfs:label": "consentGiven",
            "rdfs:comment": "Whether the subject gave consent for the verification.",
            "rdfs:domain": "finternet:CredentialMetadata",
            "rdfs:range": "xsd:boolean"
        },
        {
            "@id": "finternet:consentTimestamp",
            "@type": "rdf:Property",
            "rdfs:label": "consentTimestamp",
            "rdfs:comment": "Timestamp when consent was recorded.",
            "rdfs:domain": "finternet:CredentialMetadata",
            "rdfs:range": "xsd:dateTime"
        },
        {
            "@id": "finternet:verificationAttempts",
            "@type": "rdf:Property",
            "rdfs:label": "verificationAttempts",
            "rdfs:comment": "Number of verification attempts made.",
            "rdfs:domain": "finternet:CredentialState",
            "rdfs:range": "xsd:integer"
        }
    ]
}
