{
    "@context": [
        "https://www.w3.org/2018/credentials/v1",
        "https://finternet-io.github.io/specs/schemas/token/v1/context.jsonld",
        {
            "finternet": "https://finternet-io.github.io/specs/schemas/credential/v1#",
            "schema": "https://schema.org/",
            "xsd": "http://www.w3.org/2001/XMLSchema#",
            "sec": "https://w3id.org/security#",
            "vc": "https://www.w3.org/2018/credentials#",

            "CredentialToken": "finternet:CredentialToken",
            "CredentialMetadata": "finternet:CredentialMetadata",
            "CredentialState": "finternet:CredentialState",
            "VerificationProvider": "finternet:VerificationProvider",
            "VerificationResult": "finternet:VerificationResult",
            "DocumentVerification": "finternet:DocumentVerification",
            "BiometricVerification": "finternet:BiometricVerification",
            "IdentityEvidence": "finternet:IdentityEvidence",

            "IdentityCredential": "finternet:IdentityCredential",
            "KYCCredential": "finternet:KYCCredential",
            "DocumentCredential": "finternet:DocumentCredential",
            "BiometricCredential": "finternet:BiometricCredential",

            "credentialType": {
                "@id": "finternet:credentialType",
                "@type": "@vocab"
            },
            "CredentialType": "finternet:CredentialType",
            "identityVerification": "finternet:identityVerification",
            "documentVerification": "finternet:documentVerification",
            "biometricVerification": "finternet:biometricVerification",
            "kycVerification": "finternet:kycVerification",
            "addressVerification": "finternet:addressVerification",
            "ageVerification": "finternet:ageVerification",

            "verificationLevel": {
                "@id": "finternet:verificationLevel",
                "@type": "@vocab"
            },
            "VerificationLevel": "finternet:VerificationLevel",
            "basic": "finternet:basic",
            "standard": "finternet:standard",
            "enhanced": "finternet:enhanced",
            "premium": "finternet:premium",

            "provider": {
                "@id": "finternet:provider",
                "@type": "@id"
            },
            "providerName": "finternet:providerName",
            "providerId": "finternet:providerId",
            "providerType": {
                "@id": "finternet:providerType",
                "@type": "@vocab"
            },
            "ProviderType": "finternet:ProviderType",
            "kycProvider": "finternet:kycProvider",
            "documentProvider": "finternet:documentProvider",
            "biometricProvider": "finternet:biometricProvider",

            "journeyId": "finternet:journeyId",
            "flowId": "finternet:flowId",
            "flowVersion": {
                "@id": "finternet:flowVersion",
                "@type": "xsd:integer"
            },

            "verificationMethod": {
                "@id": "finternet:verificationMethod",
                "@type": "@vocab"
            },
            "VerificationMethod": "finternet:VerificationMethod",
            "optical": "finternet:optical",
            "ocr": "finternet:ocr",
            "nfc": "finternet:nfc",
            "api": "finternet:api",
            "manual": "finternet:manual",

            "documentType": {
                "@id": "finternet:documentType",
                "@type": "@vocab"
            },
            "DocumentType": "finternet:DocumentType",
            "passport": "finternet:passport",
            "nationalId": "finternet:nationalId",
            "driversLicense": "finternet:driversLicense",
            "pan": "finternet:pan",
            "aadhaar": "finternet:aadhaar",
            "voterId": "finternet:voterId",

            "documentCountry": "finternet:documentCountry",
            "documentNumber": "finternet:documentNumber",
            "documentExpiry": {
                "@id": "finternet:documentExpiry",
                "@type": "xsd:date"
            },
            "documentValid": {
                "@id": "finternet:documentValid",
                "@type": "xsd:boolean"
            },

            "livenessScore": {
                "@id": "finternet:livenessScore",
                "@type": "xsd:decimal"
            },
            "livenessVerified": {
                "@id": "finternet:livenessVerified",
                "@type": "xsd:boolean"
            },
            "faceMatchScore": {
                "@id": "finternet:faceMatchScore",
                "@type": "xsd:decimal"
            },
            "faceMatchVerified": {
                "@id": "finternet:faceMatchVerified",
                "@type": "xsd:boolean"
            },

            "fullName": "schema:name",
            "givenName": "schema:givenName",
            "familyName": "schema:familyName",
            "dateOfBirth": {
                "@id": "schema:birthDate",
                "@type": "xsd:date"
            },
            "gender": "schema:gender",
            "nationality": "schema:nationality",
            "address": {
                "@id": "schema:address",
                "@type": "@id"
            },

            "rawResponseRef": {
                "@id": "finternet:rawResponseRef",
                "@type": "@id"
            },
            "rawResponseHash": "finternet:rawResponseHash",
            "encryptionKeyRef": {
                "@id": "finternet:encryptionKeyRef",
                "@type": "@id"
            },

            "verificationTimestamp": {
                "@id": "finternet:verificationTimestamp",
                "@type": "xsd:dateTime"
            },
            "verificationAttempts": {
                "@id": "finternet:verificationAttempts",
                "@type": "xsd:integer"
            },
            "consentGiven": {
                "@id": "finternet:consentGiven",
                "@type": "xsd:boolean"
            },
            "consentTimestamp": {
                "@id": "finternet:consentTimestamp",
                "@type": "xsd:dateTime"
            },

            "termsOfUse": {
                "@id": "vc:termsOfUse",
                "@type": "@id"
            },
            "refreshService": {
                "@id": "vc:refreshService",
                "@type": "@id"
            },
            "credentialSchema": {
                "@id": "vc:credentialSchema",
                "@type": "@id"
            },
            "evidence": {
                "@id": "vc:evidence",
                "@type": "@id",
                "@container": "@set"
            }
        }
    ]
}
